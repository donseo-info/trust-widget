Options -Indexes
RewriteEngine On
RewriteBase /trust-widget/

# Block direct access to sensitive dirs (db/install.php доступен напрямую)
RewriteRule ^(core|models|controllers|views|logs)/ - [F,L]

# Route everything (except real files and API) through index.php
RewriteCond %{REQUEST_FILENAME} !-f
RewriteCond %{REQUEST_FILENAME} !-d
RewriteRule ^(?!api/|widgets/) index.php [QSA,L]
